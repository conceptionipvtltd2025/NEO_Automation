# Frontend (Vite) environment.
# In dev, leave VITE_API_URL unset — calls go to "/api" and Vite proxies them
# to the backend (see vite.config.ts). Set this only for a production build that
# talks to a deployed API on a different origin.
# VITE_API_URL=https://api.your-domain.com/api

# Optional: override the dev proxy target (defaults to http://localhost:4000).
# VITE_API_PROXY=http://localhost:4000
