# ── Server ────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed browser origins (the Vite dev server, your prod site).
# Use * to allow any origin (fine for local dev).
CORS_ORIGIN=http://localhost:5173

# ── MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=neo_automation

# ── Auth ──────────────────────────────────────────────────
# Change this to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Seed admin account (created on first boot if no admin exists).
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=neo@2026
